# Exclude common benign warnings that are acceptable in this codebase
# SC2155: Declare and assign separately - low risk in non-critical scripts
# SC2034: Variable appears unused - many vars are used by callers/sourced scripts
# SC2024: sudo doesn't affect redirects - intentional; LOG_FILE owned by current user
# SC2188: Redirection without command - used as truncation idiom (> file)
# SC1083: Literal braces - used in git @{upstream} syntax
disable=SC2155,SC2034,SC2024,SC2188,SC1083
